# Sample env for local dev. Copy to .env (gitignored) and fill in.
# For Render / production, set these in the dashboard as secret env vars.

# --- Gemini ---
GEMINI_API_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=

# --- Google OAuth (Web application client) ---
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional. Defaults to GOOGLE_OAUTH_CLIENT_ID.
# GOOGLE_OAUTH_AUDIENCE=

# --- CORS ---
# Comma-separated allowed origins. Add your Vercel domain in prod.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Database ---
# Local dev: leave blank to use H2 in-memory.
# Prod: postgres://user:pass@host:5432/dbname
# DATABASE_URL=
# DATABASE_DRIVER=
# DATABASE_DIALECT=

# --- Rate limiting ---
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_REFILL_PER_MINUTE=60
